# Palm Legacy — Configuration File v3.1
# Copy this file to .env, fill in your values, then run: node server.js

# ── REQUIRED: Database ──────────────────────────────────────────────────────
DB_HOST=gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com    #localhost
DB_PORT=4000
DB_USER=3jV5piZ9Jxrosf1.root     #root
DB_PASSWORD=2yqo56uxKjs5QuPU  #NewPassword123
DB_NAME=palm_legacy  #palm_legacy

# ── REQUIRED: Server ────────────────────────────────────────────────────────
# Note: port is 4000 (not 3000) — open http://localhost:4000/palm-legacy.html
PORT=4000
JWT_SECRET=a3f8c2d1e4b5a6f7c8d9e0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1

# ── REQUIRED in production: CORS ────────────────────────────────────────────
# Set to your actual domain — keeps wildcards out of production
# Leave blank for local development (defaults to *)
ALLOWED_ORIGIN=

# ── OPTIONAL: Email OTP (Gmail App Password) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Palm Legacy <no-reply@palmlegacy.com>

# ── OPTIONAL: SMS OTP (msg91.com) ───────────────────────────────────────────
MSG91_AUTH_KEY=506732Au5yET3F269d503baP1
MSG91_TEMPLATE_ID=69d4ff00d910214e8906a133

# ── OPTIONAL: WhatsApp OTP — fill ONE of WATI / Twilio / Gupshup ───────────
WATI_API_URL=
WATI_ACCESS_TOKEN=
WATI_TEMPLATE_NAME=otp_message

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

GUPSHUP_API_KEY=
GUPSHUP_SRC_NAME=
GUPSHUP_TEMPLATE_ID=

# ── OPTIONAL: Razorpay Payment (razorpay.com → Settings → API Keys) ────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── OPTIONAL: Shiprocket (shiprocket.in → Settings → API) ──────────────────
# Create account at shiprocket.in, go to Settings → API → Create API User
SHIPROCKET_EMAIL=iammanomanojk@gmail.com
SHIPROCKET_PASSWORD='l2js8$qIFoXeGNRiMnB$iG#1S3tL3XRr'
# Your registered pickup location name in Shiprocket dashboard
SHIPROCKET_PICKUP_LOCATION=Primary
# Channel ID — find at shiprocket.in → Settings → Channels (leave blank for default)
SHIPROCKET_CHANNEL_ID=
